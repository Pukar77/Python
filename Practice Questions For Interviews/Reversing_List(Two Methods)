print("Reversing an list\n")

list_number = int(input(("Hey users, please enter the number of list you want\n")))

print("Enter the list items")
list = []
for i in range(list_number):
    numbers = int(input())
    list.append(numbers)
 
print(list)

list.reverse()
print(list)

