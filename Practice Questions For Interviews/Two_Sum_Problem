print("Two sum problem")

nums = [1,2,3,4,5,6]

target = 7

def two_sum(nums, target):
    for i in range(len(nums)):
        for j in range(i+1, len(nums)):
            if nums[i] + nums[j] == target:
                return i , j
            
ans1, ans2  =two_sum(nums, target)

print(ans1,ans2)
        
